# Copy to .env and fill in. Do NOT commit .env.

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Anthropic API
ANTHROPIC_API_KEY=

# Environment
ENV=development
LOG_LEVEL=INFO

# Suppress subprocess stdout pollution (useful when running MCP servers)
TQDM_DISABLE=1
HF_HUB_DISABLE_PROGRESS_BARS=1
TRANSFORMERS_VERBOSITY=error
